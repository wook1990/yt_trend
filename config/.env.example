# config/.env.example — 이 파일을 복사해서 config/.env 로 만드세요
# cp config/.env.example config/.env

# ── 필수 ──────────────────────────────────────────────────────────────────────

# YouTube Data API v3 키 (https://console.cloud.google.com/apis)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gemini API 키 (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT 서명 키 (32자 이상 랜덤 문자열)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_random_32_char_string

# 관리자 계정 (최초 실행 시 자동 생성)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_EMAIL=admin@yourdomain.com

# ── 운영 환경만 ────────────────────────────────────────────────────────────────

# PostgreSQL 연결 (없으면 로컬 SQLite 사용)
# DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Cloud Scheduler 보안 토큰
# SCHEDULER_SECRET=change_me_to_random_string
